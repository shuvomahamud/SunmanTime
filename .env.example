# Pulled by `neonctl env pull` after linking this directory to a branch.
NEON_BRANCH=production
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@host/database?sslmode=require
NEON_AUTH_BASE_URL=https://your-auth-endpoint.neonauth.region.aws.neon.tech/database/auth
NEON_AUTH_JWKS_URL=https://your-auth-endpoint.neonauth.region.aws.neon.tech/database/auth/.well-known/jwks.json

# Generate independently for every deployment environment:
# openssl rand -base64 48
NEON_AUTH_COOKIE_SECRET=replace-with-at-least-32-random-characters

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Absolute path to the copied production database for the one-time import.
DJANGO_SQLITE_PATH=../django-apps/LeaveManagement/db.sqlite3
