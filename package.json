{
  "name": "sunmantime-nextjs",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:apply": "npx neonctl@latest psql production -- -v ON_ERROR_STOP=1 -f neon/migrations/0001_initial.sql",
    "migrate:check": "node scripts/migrate-django.mjs",
    "migrate:apply": "node --env-file=.env.local scripts/migrate-django.mjs --apply",
    "migrate:apply-and-reset": "node --env-file=.env.local scripts/migrate-django.mjs --apply --send-resets"
  },
  "dependencies": {
    "@neondatabase/auth": "^0.4.2-beta",
    "@neondatabase/serverless": "^1.1.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "lucide-react": "^1.25.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "better-sqlite3": "^12.11.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  },
  "overrides": {
    "better-auth": "1.6.23",
    "@better-auth/passkey": "1.6.23",
    "@esbuild-kit/core-utils": {
      "esbuild": "0.25.12"
    },
    "postcss": "^8.5.10",
    "uuid": "^11.1.1"
  }
}
